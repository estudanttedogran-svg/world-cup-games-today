# URL base do site
# Usado em: canonical tags, sitemap.xml, hreflang e Open Graph
# Ao comprar o domínio definitivo, altere apenas este valor e faça rebuild
PUBLIC_SITE_URL=https://worldcupgamestoday.com

# Google Analytics Measurement ID
# Formato: G-XXXXXXXXXX
# Deixe vazio se ainda não tiver — o site funciona normalmente sem ele
PUBLIC_GA_MEASUREMENT_ID=
