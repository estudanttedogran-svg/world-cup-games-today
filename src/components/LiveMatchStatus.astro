---
// LiveMatchStatus.astro — Componente Island para status ao vivo de uma partida
// Renderiza server-side com placeholder estático.
// No browser, busca live-data.json e atualiza o status/placar.
//
// Regras críticas:
// - simulation NUNCA recebe dados vivos (prop matchType='simulation' = sem atualização)
// - partial NUNCA exibe placar (apenas status badge)
// - confirmed pode exibir placar quando live ou finished
// - Qualquer falha no fetch mantém o estado server-side sem erro visível

interface Props {
  matchId: string;
  matchType?: 'confirmed' | 'partial' | 'simulation';
  defaultStatus?: string;
  locale?: string;
}

const {
  matchId,
  matchType = 'confirmed',
  defaultStatus = 'scheduled',
  locale = 'pt-br',
} = Astro.props;

// Texto de status padrão (server-side / fallback)
const defaultStatusLabels: Record<string, Record<string, string>> = {
  'pt-br': {
    scheduled:  'Agendado',
    live:       'Ao Vivo',
    finished:   'Encerrado',
    postponed:  'Adiado',
    cancelled:  'Cancelado',
  },
  'en': {
    scheduled:  'Scheduled',
    live:       'Live',
    finished:   'Finished',
    postponed:  'Postponed',
    cancelled:  'Cancelled',
  },
  'es': {
    scheduled:  'Programado',
    live:       'En Vivo',
    finished:   'Finalizado',
    postponed:  'Aplazado',
    cancelled:  'Cancelado',
  },
};

const localeLabels = defaultStatusLabels[locale] ?? defaultStatusLabels['pt-br'];
const defaultStatusText = localeLabels[defaultStatus] ?? defaultStatus;

// simulation nunca deve exibir status ao vivo
const isSimulation = matchType === 'simulation';
const canShowScore = matchType === 'confirmed';
---

{/* Renderização server-side: estado inicial estático */}
<div
  class={`live-status live-status--${defaultStatus}`}
  data-match-id={matchId}
  data-match-type={matchType}
  data-locale={locale}
  data-can-show-score={canShowScore ? 'true' : 'false'}
  aria-live="polite"
  aria-atomic="true"
>
  {isSimulation ? (
    {/* simulation: nunca busca live-data — apenas exibe label estático */}
    <span class="live-status__badge live-status__badge--simulation">
      Simulação
    </span>
  ) : (
    <>
      <span class="live-status__badge live-status__badge--{defaultStatus}" data-status-badge>
        {defaultStatus === 'live' && (
          <span class="live-status__dot" aria-hidden="true"></span>
        )}
        {defaultStatusText}
      </span>
      {/* Placar — inicialmente vazio; atualizado pelo script client-side */}
      <span class="live-status__score" data-score-display style="display:none" aria-label="Placar"></span>
    </>
  )}
</div>

{/* Script client-side — executado somente no browser */}
{!isSimulation && (
  <script define:vars={{ matchId, matchType, locale, defaultStatus }}>
    // Guard obrigatório: não executar fora do browser
    if (typeof window === 'undefined' || typeof fetch === 'undefined') {
      // noop
    } else {
      (function initLiveMatchStatus() {
        // Localização dos labels de status
        var statusLabels = {
          'pt-br': {
            scheduled:  'Agendado',
            live:       'Ao Vivo',
            finished:   'Encerrado',
            postponed:  'Adiado',
            cancelled:  'Cancelado',
          },
          'en': {
            scheduled:  'Scheduled',
            live:       'Live',
            finished:   'Finished',
            postponed:  'Postponed',
            cancelled:  'Cancelled',
          },
          'es': {
            scheduled:  'Programado',
            live:       'En Vivo',
            finished:   'Finalizado',
            postponed:  'Aplazado',
            cancelled:  'Cancelado',
          },
        };

        var localeMap = statusLabels[locale] || statusLabels['pt-br'];

        function getLabel(status) {
          return localeMap[status] || status;
        }

        // Validação mínima do live-data
        function isValidData(data) {
          if (!data || typeof data !== 'object') return false;
          if (!data.matches || typeof data.matches !== 'object' || Array.isArray(data.matches)) return false;
          return true;
        }

        // Atualiza o DOM do componente com os dados ao vivo
        function updateStatus(container, liveEntry) {
          var badge = container.querySelector('[data-status-badge]');
          var scoreDisplay = container.querySelector('[data-score-display]');

          if (!badge) return;

          var status = liveEntry.status || defaultStatus;
          var label = getLabel(status);

          // Limpar classes anteriores
          container.className = 'live-status live-status--' + status;
          badge.className = 'live-status__badge live-status__badge--' + status;

          // Montar conteúdo do badge
          var badgeContent = '';
          if (status === 'live') {
            badgeContent = '<span class="live-status__dot" aria-hidden="true"></span>';
          }
          badgeContent += label;
          if (status === 'live' && liveEntry.minute !== null && liveEntry.minute !== undefined) {
            badgeContent += " '" + liveEntry.minute;
          }
          badge.innerHTML = badgeContent;

          // Placar — somente para confirmed, quando live ou finished e scores existem
          var canShowScore = container.getAttribute('data-can-show-score') === 'true';
          if (
            canShowScore &&
            scoreDisplay &&
            (status === 'live' || status === 'finished') &&
            liveEntry.score_home !== null && liveEntry.score_home !== undefined &&
            liveEntry.score_away !== null && liveEntry.score_away !== undefined
          ) {
            scoreDisplay.textContent = liveEntry.score_home + ' – ' + liveEntry.score_away;
            scoreDisplay.style.display = '';
          } else if (scoreDisplay) {
            scoreDisplay.style.display = 'none';
          }
        }

        // Fetch com timeout e fallback silencioso
        function fetchWithTimeout(url, timeout) {
          return new Promise(function(resolve, reject) {
            var controller = typeof AbortController !== 'undefined' ? new AbortController() : null;
            var timeoutId = setTimeout(function() {
              if (controller) controller.abort();
              resolve(null); // Timeout: fallback silencioso
            }, timeout);

            var fetchOptions = controller ? { signal: controller.signal, cache: 'no-cache' } : { cache: 'no-cache' };

            fetch(url, fetchOptions)
              .then(function(response) {
                clearTimeout(timeoutId);
                if (!response.ok) {
                  resolve(null);
                  return;
                }
                return response.text();
              })
              .then(function(text) {
                if (!text || text.trim().length === 0) {
                  resolve(null);
                  return;
                }
                try {
                  resolve(JSON.parse(text));
                } catch (e) {
                  resolve(null);
                }
              })
              .catch(function() {
                clearTimeout(timeoutId);
                resolve(null); // Erro de rede: fallback silencioso
              });
          });
        }

        // Executar apenas se o browser está online (ou se navigator.onLine não existir)
        if (typeof navigator !== 'undefined' && navigator.onLine === false) {
          return; // Offline: mantém estado inicial
        }

        // Encontrar o container do componente — usando matchId como chave
        var container = document.querySelector('[data-match-id="' + matchId + '"]');
        if (!container) return;

        // Buscar live-data.json
        fetchWithTimeout('/data/live-data.json', 8000)
          .then(function(data) {
            if (!isValidData(data)) return; // Dado inválido: fallback silencioso

            var entry = data.matches && data.matches[matchId];
            if (!entry || !entry.status) return; // Partida não encontrada: fallback silencioso

            // Validar match_id antes de aplicar
            if (!matchId || typeof matchId !== 'string') return;

            updateStatus(container, entry);
          })
          .catch(function() {
            // Fallback silencioso — nunca expor erro ao usuário
          });
      })();
    }
  </script>
)}

<style>
  .live-status {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  /* === BADGE DE STATUS === */

  .live-status__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: 2px var(--space-2);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    border-radius: var(--radius-full);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  /* Agendado */
  .live-status__badge--scheduled {
    color: var(--color-scheduled);
    background-color: var(--color-scheduled-bg);
    border: 1px solid var(--color-scheduled);
  }

  /* Ao Vivo */
  .live-status__badge--live {
    color: #ffffff;
    background-color: var(--color-live);
    border: 1px solid var(--color-live);
  }

  /* Encerrado */
  .live-status__badge--finished {
    color: var(--color-text-muted);
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
  }

  /* Adiado */
  .live-status__badge--postponed {
    color: #92400e;
    background-color: #fef3c7;
    border: 1px solid #fde68a;
  }

  /* Cancelado */
  .live-status__badge--cancelled {
    color: #991b1b;
    background-color: #fef2f2;
    border: 1px solid #fecaca;
  }

  /* Simulação */
  .live-status__badge--simulation {
    color: var(--color-text-muted);
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    font-style: italic;
  }

  /* === INDICADOR "AO VIVO" (bolinha pulsante) === */

  .live-status__dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    background-color: #ffffff;
    border-radius: var(--radius-full);
    flex-shrink: 0;
    animation: live-pulse 1.5s ease-in-out infinite;
  }

  @keyframes live-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
  }

  /* === PLACAR === */

  .live-status__score {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    letter-spacing: 0.02em;
  }

  /* Destaque extra quando ao vivo */
  .live-status--live .live-status__score {
    color: var(--color-live);
  }
</style>
