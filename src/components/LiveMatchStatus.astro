---
// LiveMatchStatus.astro — Componente Island para status ao vivo de uma partida
// Renderiza server-side com placeholder estático.
// No browser, busca live-data.json e atualiza o status/placar.
//
// Regras críticas:
// - simulation NUNCA recebe dados vivos (matchType='simulation' = sem fetch)
// - partial NUNCA exibe placar (apenas status badge)
// - confirmed pode exibir placar quando live ou finished
// - Qualquer falha no fetch mantém o estado server-side sem erro visível

interface Props {
  matchId: string;
  matchType?: 'confirmed' | 'partial' | 'simulation';
  defaultStatus?: string;
  locale?: string;
}

const {
  matchId,
  matchType = 'confirmed',
  defaultStatus = 'scheduled',
  locale = 'pt-br',
} = Astro.props;

// Texto de status padrão (server-side / fallback)
const defaultStatusLabels: Record<string, Record<string, string>> = {
  'pt-br': {
    scheduled:  'Agendado',
    live:       'Ao Vivo',
    finished:   'Encerrado',
    postponed:  'Adiado',
    cancelled:  'Cancelado',
  },
  'en': {
    scheduled:  'Scheduled',
    live:       'Live',
    finished:   'Finished',
    postponed:  'Postponed',
    cancelled:  'Cancelled',
  },
  'es': {
    scheduled:  'Programado',
    live:       'En Vivo',
    finished:   'Finalizado',
    postponed:  'Aplazado',
    cancelled:  'Cancelado',
  },
};

const localeLabels = defaultStatusLabels[locale] ?? defaultStatusLabels['pt-br'];
const defaultStatusText = localeLabels[defaultStatus] ?? defaultStatus;

// simulation nunca deve exibir status ao vivo
const isSimulation = matchType === 'simulation';
const canShowScore = matchType === 'confirmed';
---

<div
  class={`live-status live-status--${defaultStatus}`}
  data-match-id={matchId}
  data-match-type={matchType}
  data-locale={locale}
  data-can-show-score={canShowScore ? 'true' : 'false'}
  data-is-simulation={isSimulation ? 'true' : 'false'}
  aria-live="polite"
  aria-atomic="true"
>
  {isSimulation ? (
    <span class="live-status__badge live-status__badge--simulation">
      Simula&ccedil;&atilde;o
    </span>
  ) : (
    <span class={`live-status__badge live-status__badge--${defaultStatus}`} data-status-badge>
      {defaultStatus === 'live' && (
        <span class="live-status__dot" aria-hidden="true"></span>
      )}
      {defaultStatusText}
    </span>
  )}
  <span class="live-status__score" data-score-display style="display:none" aria-label="Placar"></span>
</div>

<script>
  // Guard obrigatório: não executar fora do browser
  if (typeof window !== 'undefined' && typeof fetch !== 'undefined') {
    (function initAllLiveStatuses() {
      // Localização dos labels de status (inline — sem importar módulos)
      var statusLabels = {
        'pt-br': {
          scheduled:  'Agendado',
          live:       'Ao Vivo',
          finished:   'Encerrado',
          postponed:  'Adiado',
          cancelled:  'Cancelado',
        },
        en: {
          scheduled:  'Scheduled',
          live:       'Live',
          finished:   'Finished',
          postponed:  'Postponed',
          cancelled:  'Cancelled',
        },
        es: {
          scheduled:  'Programado',
          live:       'En Vivo',
          finished:   'Finalizado',
          postponed:  'Aplazado',
          cancelled:  'Cancelado',
        },
      };

      function getLabel(status, locale) {
        var map = statusLabels[locale] || statusLabels['pt-br'];
        return map[status] || status;
      }

      // Validação mínima do live-data
      function isValidData(data) {
        if (!data || typeof data !== 'object') return false;
        if (!data.matches || typeof data.matches !== 'object' || Array.isArray(data.matches)) return false;
        return true;
      }

      // Atualiza o DOM de um container de status com os dados ao vivo
      function updateContainer(container, liveEntry, locale) {
        var badge = container.querySelector('[data-status-badge]');
        var scoreDisplay = container.querySelector('[data-score-display]');
        if (!badge) return;

        var status = liveEntry.status || 'scheduled';
        var label = getLabel(status, locale);

        // Atualizar classes
        container.className = 'live-status live-status--' + status;
        badge.className = 'live-status__badge live-status__badge--' + status;

        // Montar conteúdo do badge
        var dotHtml = status === 'live'
          ? '<span class="live-status__dot" aria-hidden="true"></span>'
          : '';

        var minuteText = '';
        if (
          status === 'live' &&
          liveEntry.minute !== null &&
          liveEntry.minute !== undefined
        ) {
          minuteText = " '" + liveEntry.minute;
        }

        badge.innerHTML = dotHtml + label + minuteText;

        // Placar — somente confirmed, quando live/finished e scores existem
        var canShowScore = container.getAttribute('data-can-show-score') === 'true';
        if (
          canShowScore &&
          scoreDisplay &&
          (status === 'live' || status === 'finished') &&
          liveEntry.score_home !== null &&
          liveEntry.score_home !== undefined &&
          liveEntry.score_away !== null &&
          liveEntry.score_away !== undefined
        ) {
          scoreDisplay.textContent = liveEntry.score_home + ' – ' + liveEntry.score_away;
          scoreDisplay.style.display = '';
        } else if (scoreDisplay) {
          scoreDisplay.style.display = 'none';
        }
      }

      // Cache de live-data em memória (evitar múltiplos fetches na mesma página)
      var liveDataCache = null;
      var fetchPromise = null;

      function getLiveData() {
        if (liveDataCache !== null) {
          return Promise.resolve(liveDataCache);
        }
        if (fetchPromise !== null) {
          return fetchPromise;
        }

        fetchPromise = new Promise(function(resolve) {
          // Verificar se está offline
          if (typeof navigator !== 'undefined' && navigator.onLine === false) {
            resolve(null);
            return;
          }

          var controller = typeof AbortController !== 'undefined' ? new AbortController() : null;
          var timeoutId = setTimeout(function() {
            if (controller) controller.abort();
            resolve(null);
          }, 8000);

          var fetchOptions = controller
            ? { signal: controller.signal, cache: 'no-cache' }
            : { cache: 'no-cache' };

          fetch('/data/live-data.json', fetchOptions)
            .then(function(response) {
              clearTimeout(timeoutId);
              if (!response.ok) { resolve(null); return null; }
              return response.text();
            })
            .then(function(text) {
              if (!text || !text.trim()) { resolve(null); return; }
              try {
                var parsed = JSON.parse(text);
                if (isValidData(parsed)) {
                  liveDataCache = parsed;
                  resolve(parsed);
                } else {
                  resolve(null);
                }
              } catch (e) {
                resolve(null);
              }
            })
            .catch(function() {
              clearTimeout(timeoutId);
              resolve(null);
            });
        });

        return fetchPromise;
      }

      // Encontrar todos os containers de status na página
      var containers = document.querySelectorAll('[data-match-id]');
      if (!containers.length) return;

      // Executar fetch uma única vez e atualizar todos os containers
      getLiveData().then(function(data) {
        if (!isValidData(data)) return;

        containers.forEach(function(container) {
          // simulation nunca recebe dados vivos
          if (container.getAttribute('data-is-simulation') === 'true') return;

          var matchId = container.getAttribute('data-match-id');
          if (!matchId) return;

          var locale = container.getAttribute('data-locale') || 'pt-br';
          var entry = data.matches && data.matches[matchId];
          if (!entry || !entry.status) return;

          updateContainer(container, entry, locale);
        });
      }).catch(function() {
        // Fallback silencioso — nunca expor erro ao usuário
      });
    })();
  }
</script>

<style>
  .live-status {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  /* === BADGE DE STATUS === */

  .live-status__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: 2px var(--space-2);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    border-radius: var(--radius-full);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  /* Agendado */
  .live-status__badge--scheduled {
    color: var(--color-scheduled);
    background-color: var(--color-scheduled-bg);
    border: 1px solid var(--color-scheduled);
  }

  /* Ao Vivo */
  .live-status__badge--live {
    color: #ffffff;
    background-color: var(--color-live);
    border: 1px solid var(--color-live);
  }

  /* Encerrado */
  .live-status__badge--finished {
    color: var(--color-text-muted);
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
  }

  /* Adiado */
  .live-status__badge--postponed {
    color: #92400e;
    background-color: #fef3c7;
    border: 1px solid #fde68a;
  }

  /* Cancelado */
  .live-status__badge--cancelled {
    color: #991b1b;
    background-color: #fef2f2;
    border: 1px solid #fecaca;
  }

  /* Simulacao */
  .live-status__badge--simulation {
    color: var(--color-text-muted);
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    font-style: italic;
  }

  /* === INDICADOR "AO VIVO" (bolinha pulsante) === */

  .live-status__dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    background-color: #ffffff;
    border-radius: var(--radius-full);
    flex-shrink: 0;
    animation: live-pulse 1.5s ease-in-out infinite;
  }

  @keyframes live-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
  }

  /* === PLACAR === */

  .live-status__score {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    letter-spacing: 0.02em;
  }

  /* Destaque extra quando ao vivo */
  .live-status--live .live-status__score {
    color: var(--color-live);
  }
</style>
