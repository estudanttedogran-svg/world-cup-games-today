---
import { buildWhatsAppText, buildWhatsAppUrl } from '../utils/share.ts';
import type { Locale } from '../types/index.ts';

interface Props {
  locale?: Locale;
  // Contexto do jogo (opcional — se não passado, usa modo genérico)
  matchType?: 'confirmed' | 'partial' | 'simulation' | 'generic';
  homeTeamName?: string;
  awayTeamName?: string;
  dateFormatted?: string;
  timeFormatted?: string;
  // URL canônica da página atual (usada no SSR para pré-gerar URL do WA)
  // O client-side JS sobrescreve com window.location.href
  pageUrl?: string;
  // Props legadas (mantidas para compatibilidade com chamadas existentes)
  matchId?: string;
  matchTitle?: string;
}

const {
  locale = 'pt-br',
  matchType = 'generic',
  homeTeamName,
  awayTeamName,
  dateFormatted,
  timeFormatted,
  pageUrl = 'https://worldcupgamestoday.com',
  // Props legadas ignoradas silenciosamente (substituídas pelos novos contextos)
  matchId: _matchId,
  matchTitle: _matchTitle,
} = Astro.props;

// Pré-gerar URL de WhatsApp server-side (será sobrescrita pelo JS com a URL real)
const serverShareText = buildWhatsAppText({
  matchType,
  homeTeamName,
  awayTeamName,
  dateFormatted,
  timeFormatted,
  pageUrl,
  locale: locale as Locale,
});
const serverWhatsAppUrl = buildWhatsAppUrl(serverShareText);

// Labels por locale
const labels = {
  'pt-br': {
    whatsapp: 'Compartilhar no WhatsApp',
    copy: 'Copiar link',
    copied: 'Copiado!',
    copyFailed: 'Erro ao copiar',
    shareTitle: 'Compartilhe:',
  },
  'en': {
    whatsapp: 'Share on WhatsApp',
    copy: 'Copy link',
    copied: 'Copied!',
    copyFailed: 'Failed to copy',
    shareTitle: 'Share:',
  },
  'es': {
    whatsapp: 'Compartir en WhatsApp',
    copy: 'Copiar enlace',
    copied: '¡Copiado!',
    copyFailed: 'Error al copiar',
    shareTitle: 'Compartir:',
  },
} as const;

const t = labels[locale as keyof typeof labels] ?? labels['pt-br'];
---

<div class="share-buttons" data-share-component data-locale={locale}>
  <span class="share-buttons__title">{t.shareTitle}</span>

  <div class="share-buttons__group">
    <!-- WhatsApp -->
    <a
      id="share-whatsapp"
      href={serverWhatsAppUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="share-btn share-btn--whatsapp"
      aria-label={t.whatsapp}
      data-match-type={matchType}
      data-home-team={homeTeamName ?? ''}
      data-away-team={awayTeamName ?? ''}
      data-date={dateFormatted ?? ''}
      data-time={timeFormatted ?? ''}
    >
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
      </svg>
      <span>{t.whatsapp}</span>
    </a>

    <!-- Copiar link -->
    <button
      id="share-copy"
      type="button"
      class="share-btn share-btn--copy"
      aria-label={t.copy}
      data-copy-label={t.copy}
      data-copied-label={t.copied}
      data-failed-label={t.copyFailed}
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
      </svg>
      <span>{t.copy}</span>
    </button>
  </div>
</div>

<script>
  (function () {
    if (typeof window === 'undefined') return;

    // --- WhatsApp: atualizar URL com a URL real da página ---
    const waBtn = document.getElementById('share-whatsapp') as HTMLAnchorElement | null;
    if (waBtn) {
      const pageUrl = window.location.href;
      const matchType = waBtn.dataset.matchType ?? 'generic';
      const homeTeam = waBtn.dataset.homeTeam || undefined;
      const awayTeam = waBtn.dataset.awayTeam || undefined;
      const date = waBtn.dataset.date || undefined;
      const time = waBtn.dataset.time || undefined;

      let text = '';
      if (matchType === 'confirmed' && homeTeam && awayTeam) {
        const datePart = date && time ? `\n🕐 ${date} às ${time}` : '';
        text = `⚽ ${homeTeam} x ${awayTeam}${datePart}\nVeja no World Cup Games Today: ${pageUrl}`;
      } else if (matchType === 'partial') {
        const datePart = date ? `\n📅 ${date}` : '';
        text = `⚽ Próxima fase da Copa 2026 — vagas a definir${datePart}\nVeja no World Cup Games Today: ${pageUrl}`;
      } else {
        text = `⚽ Copa do Mundo 2026 — Veja os jogos no seu horário local\n${pageUrl}`;
      }

      waBtn.setAttribute('href', `https://wa.me/?text=${encodeURIComponent(text)}`);
    }

    // --- Copiar link ---
    const copyBtn = document.getElementById('share-copy') as HTMLButtonElement | null;
    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        const url = window.location.href;
        const span = copyBtn.querySelector('span');
        const originalLabel = copyBtn.dataset.copyLabel ?? 'Copiar link';
        const copiedLabel = copyBtn.dataset.copiedLabel ?? 'Copiado!';
        const failedLabel = copyBtn.dataset.failedLabel ?? 'Erro ao copiar';

        let success = false;
        try {
          if (navigator.clipboard && navigator.clipboard.writeText) {
            await navigator.clipboard.writeText(url);
            success = true;
          } else {
            const ta = document.createElement('textarea');
            ta.value = url;
            ta.style.position = 'fixed';
            ta.style.opacity = '0';
            document.body.appendChild(ta);
            ta.focus();
            ta.select();
            success = document.execCommand('copy');
            document.body.removeChild(ta);
          }
        } catch {
          success = false;
        }

        if (span) span.textContent = success ? copiedLabel : failedLabel;
        copyBtn.classList.add(success ? 'share-btn--copied' : 'share-btn--failed');
        setTimeout(() => {
          if (span) span.textContent = originalLabel;
          copyBtn.classList.remove('share-btn--copied', 'share-btn--failed');
        }, 2000);
      });
    }
  })();
</script>

<style>
  .share-buttons {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .share-buttons__title {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .share-buttons__group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    font-family: var(--font-sans);
    text-decoration: none;
    cursor: pointer;
    border: 1px solid transparent;
    transition: background var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast);
    background-color: var(--color-bg-card);
    color: var(--color-text);
  }

  .share-btn:hover,
  .share-btn:focus {
    text-decoration: none;
  }

  .share-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* WhatsApp */
  .share-btn--whatsapp {
    background: #25d366;
    color: #fff;
    border-color: #1ebe5d;
  }

  .share-btn--whatsapp:hover,
  .share-btn--whatsapp:focus {
    background: #1ebe5d;
    color: #fff;
  }

  /* Copiar link */
  .share-btn--copy {
    background: var(--color-bg-alt);
    color: var(--color-text);
    border-color: var(--color-border);
  }

  .share-btn--copy:hover,
  .share-btn--copy:focus {
    border-color: var(--color-accent);
    background: var(--color-bg-alt);
  }

  .share-btn--copy.share-btn--copied {
    background: var(--color-live-bg);
    border-color: var(--color-live);
    color: #15803d;
  }

  .share-btn--copy.share-btn--failed {
    background: #fff3f3;
    border-color: #f87171;
    color: #dc2626;
  }

  .share-btn svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
</style>
