---
import type { Team, Locale } from '../types/index.ts';

interface Props {
  teams: Team[];
  selectedTeamSlug?: string;
  locale?: Locale;
}

const {
  teams,
  selectedTeamSlug,
  locale = 'pt-br',
} = Astro.props;

const labels: Record<string, { title: string; placeholder: string; apply: string }> = {
  'pt-br': { title: 'Acompanhar seleção:', placeholder: 'Selecione uma seleção', apply: 'Aplicar' },
  'en':    { title: 'Follow team:', placeholder: 'Select a team', apply: 'Apply' },
  'es':    { title: 'Seguir selección:', placeholder: 'Selecciona una selección', apply: 'Aplicar' },
};

const ui = labels[locale] ?? labels['pt-br'];
---

<div class="team-selector" id="team-selector">
  <label for="team-select" class="team-selector__label">
    {ui.title}
  </label>
  <div class="team-selector__control">
    <select id="team-select" class="team-selector__select" name="team">
      <option value="">{ui.placeholder}</option>
      {teams.map((team) => (
        <option
          value={team.slug}
          selected={team.slug === selectedTeamSlug}
        >
          {team.flag} {team.name[locale] ?? team.name['en']}
        </option>
      ))}
    </select>
    <button type="button" class="team-selector__btn" id="team-apply-btn">
      {ui.apply}
    </button>
  </div>
</div>

<script>
  (function () {
    if (typeof window === 'undefined') return;

    const select = document.getElementById('team-select') as HTMLSelectElement | null;
    const btn = document.getElementById('team-apply-btn') as HTMLButtonElement | null;

    // Lê preferência salva e aplica ao select
    try {
      const raw = localStorage.getItem('wcgt_prefs');
      if (raw) {
        const prefs = JSON.parse(raw);
        if (prefs.team && select) {
          const opt = select.querySelector(`option[value="${prefs.team}"]`) as HTMLOptionElement | null;
          if (opt) {
            select.value = prefs.team;
          }
        }
      }
    } catch (_) {}

    if (btn && select) {
      btn.addEventListener('click', function () {
        const chosen = select.value;
        if (!chosen) return;
        try {
          const raw = localStorage.getItem('wcgt_prefs');
          const prefs = raw ? JSON.parse(raw) : {};
          prefs.team = chosen;
          localStorage.setItem('wcgt_prefs', JSON.stringify(prefs));
        } catch (_) {}
        window.location.reload();
      });
    }
  })();
</script>

<style>
  .team-selector {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .team-selector__label {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .team-selector__control {
    display: flex;
    gap: var(--space-2);
    align-items: center;
  }

  .team-selector__select {
    flex: 1;
    padding: var(--space-2) var(--space-3);
    font-size: var(--font-size-sm);
    font-family: var(--font-sans);
    color: var(--color-text);
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    min-width: 0;
    min-height: 44px;
  }

  .team-selector__select:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .team-selector__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: var(--space-2) var(--space-3);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-inverse);
    background-color: var(--color-accent);
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    white-space: nowrap;
    transition: background-color var(--transition-fast);
  }

  .team-selector__btn:hover,
  .team-selector__btn:focus {
    background-color: var(--color-accent-hover);
  }

  .team-selector__btn:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>
