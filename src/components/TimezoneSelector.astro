---
import { getPopularTimezones, getTimezoneLabel } from '../utils/timezone.ts';
import type { Locale } from '../types/index.ts';

interface Props {
  currentTimezone: string;
  locale?: Locale;
  displayLabel?: string;
}

const {
  currentTimezone,
  locale = 'pt-br',
  displayLabel,
} = Astro.props;

const popularTimezones = getPopularTimezones(locale);
const resolvedLabel = displayLabel || getTimezoneLabel(currentTimezone);

const labels: Record<string, { title: string; change: string; current: string }> = {
  'pt-br': { title: 'Fuso horário', change: 'Trocar fuso', current: 'Atual:' },
  'en':    { title: 'Time zone',    change: 'Change zone',  current: 'Current:' },
  'es':    { title: 'Zona horaria', change: 'Cambiar zona', current: 'Actual:' },
};

const ui = labels[locale] ?? labels['pt-br'];
---

<div class="tz-selector" id="tz-selector">
  <div class="tz-selector__header">
    <span class="tz-selector__title">{ui.title}</span>
    <span class="tz-selector__current">
      <span class="tz-selector__current-label">{ui.current}</span>
      <strong class="tz-selector__value" id="tz-display">{resolvedLabel}</strong>
    </span>
  </div>

  <div class="tz-selector__control">
    <label for="tz-select" class="sr-only">{ui.change}</label>
    <select id="tz-select" class="tz-selector__select" name="timezone">
      {popularTimezones.map((tz) => (
        <option
          value={tz.value}
          selected={tz.value === currentTimezone}
        >
          {tz.label} — {tz.region}
        </option>
      ))}
    </select>
    <button type="button" class="tz-selector__btn" id="tz-apply-btn">
      {ui.change}
    </button>
  </div>
</div>

<script>
  (function () {
    if (typeof window === 'undefined') return;

    const select = document.getElementById('tz-select') as HTMLSelectElement | null;
    const display = document.getElementById('tz-display') as HTMLElement | null;
    const btn = document.getElementById('tz-apply-btn') as HTMLButtonElement | null;

    // Lê preferência salva e aplica ao select
    try {
      const raw = localStorage.getItem('wcgt_prefs');
      if (raw) {
        const prefs = JSON.parse(raw);
        if (prefs.timezone && select) {
          const opt = select.querySelector(`option[value="${prefs.timezone}"]`) as HTMLOptionElement | null;
          if (opt) {
            select.value = prefs.timezone;
            if (display) display.textContent = opt.textContent?.replace(/\s*—.*$/, '').trim() ?? prefs.timezone;
          }
        }
      }
    } catch (_) {}

    if (btn && select) {
      btn.addEventListener('click', function () {
        const chosen = select.value;
        try {
          const raw = localStorage.getItem('wcgt_prefs');
          const prefs = raw ? JSON.parse(raw) : {};
          prefs.timezone = chosen;
          localStorage.setItem('wcgt_prefs', JSON.stringify(prefs));
        } catch (_) {}
        // Update selector display label
        if (display) {
          const opt = select.options[select.selectedIndex];
          if (opt) display.textContent = opt.textContent.replace(/\s*—.*$/, '').trim();
        }
        // Dispatch event so the timezone updater script reformats all datetime elements
        document.dispatchEvent(new CustomEvent('wcgt:timezone-change', { detail: { timezone: chosen } }));
      });
    }
  })();
</script>

<style>
  .tz-selector {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .tz-selector__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .tz-selector__title {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .tz-selector__current {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .tz-selector__value {
    color: var(--color-text);
    font-weight: var(--font-weight-semibold);
  }

  .tz-selector__control {
    display: flex;
    gap: var(--space-2);
    align-items: center;
  }

  .tz-selector__select {
    flex: 1;
    padding: var(--space-2) var(--space-3);
    font-size: var(--font-size-sm);
    font-family: var(--font-sans);
    color: var(--color-text);
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    min-width: 0;
    min-height: 44px;
  }

  .tz-selector__select:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .tz-selector__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: var(--space-2) var(--space-3);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-inverse);
    background-color: var(--color-primary);
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    white-space: nowrap;
    transition: background-color var(--transition-fast);
  }

  .tz-selector__btn:hover,
  .tz-selector__btn:focus {
    background-color: var(--color-primary-light);
  }

  .tz-selector__btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>
