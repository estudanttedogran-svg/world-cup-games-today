---
import type { Locale } from '../types/index.ts';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/reset.css';
import '../styles/variables.css';
import '../styles/global.css';

interface HreflangAlternate {
  hreflang: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  lang?: string;
  locale?: Locale;
  canonical?: string;
  canonicalUrl?: string;
  alternates?: HreflangAlternate[];
  ogType?: string;
  ogImage?: string;
  ogLocale?: string;
  ogLocaleAlternates?: string[];
  twitterCard?: string;
}

const {
  title,
  description = '',
  lang = 'en',
  locale = 'en',
  canonical,
  canonicalUrl: canonicalUrlProp,
  alternates,
  ogType,
  ogImage,
  ogLocale: ogLocaleProp,
  ogLocaleAlternates: ogLocaleAlternatesProp,
  twitterCard,
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://worldcupgamestoday.com';
// canonicalUrlProp tem prioridade; depois canonical (legacy); depois pathname automático
const canonicalUrl = canonicalUrlProp || canonical || `${siteUrl}${Astro.url.pathname}`;
const ogUrl = canonicalUrl;
const defaultOgImage = `${siteUrl}/images/og-default.svg`;
const resolvedOgImage = ogImage || defaultOgImage;

// Derivação automática de ogLocale a partir de locale
const localeToOgLocale: Record<string, string> = {
  'pt-br': 'pt_BR',
  'en': 'en_US',
  'es': 'es_ES',
};
const resolvedOgLocale = ogLocaleProp ?? (locale ? localeToOgLocale[locale] : undefined);

// Derivação automática de ogLocaleAlternates a partir de alternates (hreflang)
const hreflangToOgLocale: Record<string, string> = {
  'pt-BR': 'pt_BR',
  'en': 'en_US',
  'es': 'es_ES',
};
const resolvedOgLocaleAlternates = ogLocaleAlternatesProp
  ?? alternates
    ?.map((a) => hreflangToOgLocale[a.hreflang])
    .filter((v): v is string => Boolean(v));
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>

    {description && <meta name="description" content={description} />}

    <link rel="canonical" href={canonicalUrl} />

    <!-- hreflang alternates -->
    {alternates?.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType ?? 'website'} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:site_name" content="World Cup Games Today" />
    {resolvedOgLocale && <meta property="og:locale" content={resolvedOgLocale} />}
    {resolvedOgLocaleAlternates?.map((alt) => (
      <meta property="og:locale:alternate" content={alt} />
    ))}
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content={twitterCard ?? 'summary_large_image'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- Slot para meta tags extras (ex: hreflang, JSON-LD) -->
    <slot name="head" />
  </head>
  <body>
    <Header locale={locale} />

    <main id="main-content">
      <slot />
    </main>

    <Footer locale={locale} />

    <!-- Slot para scripts inline -->
    <slot name="scripts" />

    <!-- Timezone updater: reformata elementos [data-utc-datetime] quando o fuso muda -->
    <script is:inline>
    (function () {
      if (typeof window === 'undefined' || typeof document === 'undefined') return;

      function getIntlLocale() {
        var lang = (document.documentElement.lang || 'en').toLowerCase();
        if (lang.startsWith('pt')) return 'pt-BR';
        if (lang.startsWith('es')) return 'es-ES';
        return 'en-US';
      }

      function getSavedTz() {
        try {
          var raw = localStorage.getItem('wcgt_prefs');
          if (raw) {
            var prefs = JSON.parse(raw);
            if (prefs.timezone && typeof prefs.timezone === 'string') return prefs.timezone;
          }
        } catch (e) {}
        return null;
      }

      function isValidTz(tz) {
        try { Intl.DateTimeFormat(undefined, { timeZone: tz }); return true; } catch (e) { return false; }
      }

      function fmt(utcStr, format, tz, intlLocale) {
        try {
          var date = new Date(utcStr);
          if (isNaN(date.getTime())) return '';
          var h12 = intlLocale === 'en-US';
          var timeOpts = { timeZone: tz, hour: '2-digit', minute: '2-digit', hour12: h12 };
          var dateOpts = { timeZone: tz, year: 'numeric', month: 'short', day: 'numeric' };
          var wdOpts   = { timeZone: tz, weekday: 'long' };
          if (format === 'time')    return new Intl.DateTimeFormat(intlLocale, timeOpts).format(date);
          if (format === 'date')    return new Intl.DateTimeFormat(intlLocale, dateOpts).format(date);
          if (format === 'weekday') return new Intl.DateTimeFormat(intlLocale, wdOpts).format(date);
          if (format === 'weekday-date') {
            var w = new Intl.DateTimeFormat(intlLocale, wdOpts).format(date);
            var d = new Intl.DateTimeFormat(intlLocale, dateOpts).format(date);
            return w + ', ' + d;
          }
          if (format === 'full') {
            var wf = new Intl.DateTimeFormat(intlLocale, wdOpts).format(date);
            var df = new Intl.DateTimeFormat(intlLocale, dateOpts).format(date);
            var tf = new Intl.DateTimeFormat(intlLocale, timeOpts).format(date);
            return wf + ', ' + df + ' • ' + tf;
          }
        } catch (e) {}
        return '';
      }

      function applyTz(tz) {
        if (!tz || !isValidTz(tz)) return;
        var intlLocale = getIntlLocale();
        var els = document.querySelectorAll('[data-utc-datetime][data-tz-format]');
        for (var i = 0; i < els.length; i++) {
          var el = els[i];
          var utcStr = el.getAttribute('data-utc-datetime');
          var format = el.getAttribute('data-tz-format');
          if (!utcStr || !format) continue;
          var result = fmt(utcStr, format, tz, intlLocale);
          if (result) el.textContent = result;
        }
        var city = tz.split('/').pop().replace(/_/g, ' ');
        var labelEls = document.querySelectorAll('[data-tz-label]');
        for (var j = 0; j < labelEls.length; j++) {
          labelEls[j].textContent = city;
        }
      }

      function run() {
        var tz = getSavedTz();
        if (tz) applyTz(tz);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', run);
      } else {
        run();
      }

      document.addEventListener('wcgt:timezone-change', function (e) {
        if (e && e.detail && e.detail.timezone) applyTz(e.detail.timezone);
      });
    })();
    </script>

    <!-- Google Analytics — carrega apenas se PUBLIC_GA_MEASUREMENT_ID estiver configurado -->
    {import.meta.env.PUBLIC_GA_MEASUREMENT_ID && (
      <Fragment>
        <script
          is:inline
          async
          src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_MEASUREMENT_ID}`}
        ></script>
        <script is:inline define:vars={{ gaId: import.meta.env.PUBLIC_GA_MEASUREMENT_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId, { anonymize_ip: true });
        </script>
      </Fragment>
    )}
  </body>
</html>
