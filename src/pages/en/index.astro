---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdPlaceholder from '../../components/AdPlaceholder.astro';
import TimezoneSelector from '../../components/TimezoneSelector.astro';
import TeamSelector from '../../components/TeamSelector.astro';
import NextMatchCard from '../../components/NextMatchCard.astro';
import MatchList from '../../components/MatchList.astro';
import TodayMatches from '../../components/TodayMatches.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import FAQSection from '../../components/FAQSection.astro';

import type { Match, Team } from '../../types/index.ts';
import matchesData from '../../data/matches.json';
import teamsData from '../../data/teams.json';
import {
  getNextConfirmedMatch,
  getTodaysConfirmedMatches,
  getConfirmedMatchesByTeam,
  getTeamName,
} from '../../utils/matches.ts';

const allMatches = (matchesData as { matches: Match[] }).matches;
const allTeams = (teamsData as { teams: Team[] }).teams;

const defaultTimezone = 'America/New_York';
const defaultTeamSlug = 'northland';

const nextMatch = getNextConfirmedMatch(allMatches, defaultTeamSlug);
const todayMatches = getTodaysConfirmedMatches(allMatches, defaultTimezone);
const teamMatches = getConfirmedMatchesByTeam(allMatches, defaultTeamSlug);

const teamDisplayName = getTeamName(allTeams, defaultTeamSlug, 'en');

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://worldcupgamestoday.com';
const canonicalUrl = `${siteUrl}/en/`;
const alternates = [
  { hreflang: 'x-default', href: `${siteUrl}/` },
  { hreflang: 'pt-BR',     href: `${siteUrl}/pt-br/` },
  { hreflang: 'en',        href: `${siteUrl}/en/` },
  { hreflang: 'es',        href: `${siteUrl}/es/` },
];
---

<BaseLayout
  title="World Cup 2026 Matches — World Cup Games Today"
  description="See all 2026 World Cup matches in your local time. Schedule automatically updated to your timezone."
  lang="en"
  locale="en"
  canonicalUrl={canonicalUrl}
  alternates={alternates}
>
  <div class="container">

    <!-- HERO -->
    <section class="hero">
      <h1>2026 World Cup Matches</h1>
      <p>See every match in your local time &mdash; no timezone conversion needed.</p>
    </section>

    <!-- MOCK DATA WARNING -->
    <div class="mock-warning" role="alert">
      &#9888; This site uses demonstration data (MOCK). The data shown is fictional.
    </div>

    <!-- SELECTORS: TIMEZONE AND TEAM -->
    <section class="selectors" aria-label="Preferences">
      <TimezoneSelector
        currentTimezone={defaultTimezone}
        locale="en"
      />
      <TeamSelector
        teams={allTeams}
        selectedTeamSlug={defaultTeamSlug}
        locale="en"
      />
    </section>

    <!-- NEXT MATCH FOR SELECTED TEAM -->
    <section class="next-match" aria-label="Next match">
      <NextMatchCard
        match={nextMatch}
        teams={allTeams}
        timezone={defaultTimezone}
        locale="en"
      />
    </section>

    <!-- AD PLACEHOLDER -->
    <AdPlaceholder slot="middle" label="Advertisement" />

    <!-- TODAY'S MATCHES -->
    <section class="today-matches" aria-label="Today's matches">
      <h2>Today's Matches</h2>
      <TodayMatches
        matches={allMatches}
        teams={allTeams}
        timezone={defaultTimezone}
        locale="en"
      />
    </section>

    <!-- ALL MATCHES FOR SELECTED TEAM -->
    <section class="team-matches" aria-label={`Matches for ${teamDisplayName}`}>
      <h2>{teamDisplayName} Matches</h2>
      <MatchList
        matches={teamMatches}
        teams={allTeams}
        timezone={defaultTimezone}
        locale="en"
        title="Team matches"
        emptyMessage="No confirmed matches available for this team."
      />
    </section>

    <!-- SHARE -->
    <section class="share" aria-label="Share">
      <h2>Share</h2>
      <ShareButtons
        locale="en"
        matchTitle="2026 World Cup"
      />
    </section>

    <!-- SEO TEXT -->
    <section class="seo-text" aria-label="About the 2026 World Cup">
      <h2>2026 World Cup &mdash; Match Times in Your Timezone</h2>
      <p>
        The 2026 FIFA World Cup will be held in the United States, Canada, and Mexico.
        Use World Cup Games Today to follow every match in your local time,
        without manually converting timezones.
      </p>
      <p>
        Select your favorite national team and see when they play &mdash; with times
        automatically updated for any city in the world.
      </p>
    </section>

    <!-- FAQ -->
    <FAQSection
      heading="Frequently Asked Questions"
      items={[
        {
          question: 'When does the 2026 World Cup start?',
          answer: 'The 2026 World Cup starts on June 11, 2026 and ends on July 19, 2026.',
        },
        {
          question: 'Where is the 2026 World Cup being held?',
          answer: 'The 2026 World Cup will be hosted by the United States, Canada and Mexico.',
        },
        {
          question: 'How many teams are in the 2026 World Cup?',
          answer: 'The 2026 World Cup will feature 48 teams, the largest field in tournament history.',
        },
        {
          question: 'How many matches are in the 2026 World Cup?',
          answer: 'The 2026 World Cup will include 104 matches in total.',
        },
        {
          question: 'Are match times shown in my local time?',
          answer: 'Yes. The site detects your browser timezone and lets you manually switch to another city or region.',
        },
        {
          question: 'Do I need an account to use the site?',
          answer: 'No. World Cup Games Today works without login or registration.',
        },
      ]}
    />

  </div>
</BaseLayout>
