---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdPlaceholder from '../../components/AdPlaceholder.astro';
import TimezoneSelector from '../../components/TimezoneSelector.astro';
import TeamSelector from '../../components/TeamSelector.astro';
import NextMatchCard from '../../components/NextMatchCard.astro';
import MatchList from '../../components/MatchList.astro';
import TodayMatches from '../../components/TodayMatches.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import FAQSection from '../../components/FAQSection.astro';

import type { Match, Team } from '../../types/index.ts';
import matchesData from '../../data/matches.json';
import teamsData from '../../data/teams.json';
import {
  getNextConfirmedMatch,
  getTodaysConfirmedMatches,
  getConfirmedMatchesByTeam,
  getTeamName,
} from '../../utils/matches.ts';

const allMatches = (matchesData as { matches: Match[] }).matches;
const allTeams = (teamsData as { teams: Team[] }).teams;

const defaultTimezone = 'America/Mexico_City';
const defaultTeamSlug = 'northland';

const nextMatch = getNextConfirmedMatch(allMatches, defaultTeamSlug);
const todayMatches = getTodaysConfirmedMatches(allMatches, defaultTimezone);
const teamMatches = getConfirmedMatchesByTeam(allMatches, defaultTeamSlug);

const teamDisplayName = getTeamName(allTeams, defaultTeamSlug, 'es');

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://worldcupgamestoday.com';
const canonicalUrl = `${siteUrl}/es/`;
const alternates = [
  { hreflang: 'x-default', href: `${siteUrl}/` },
  { hreflang: 'pt-BR',     href: `${siteUrl}/pt-br/` },
  { hreflang: 'en',        href: `${siteUrl}/en/` },
  { hreflang: 'es',        href: `${siteUrl}/es/` },
];
---

<BaseLayout
  title="Copa del Mundo 2026 — Partidos en tu horario local | World Cup Games Today"
  description="Ve todos los partidos del Mundial FIFA 2026 en tu horario local. Horarios actualizados automáticamente a tu zona horaria."
  lang="es"
  locale="es"
  canonicalUrl={canonicalUrl}
  alternates={alternates}
>
  <div class="container">

    <!-- HERO -->
    <section class="hero">
      <h1>Copa del Mundo 2026 &mdash; Partidos en tu horario local</h1>
      <p>Ve todos los partidos en tu horario local &mdash; sin convertir zonas horarias.</p>
    </section>

    <!-- AVISO MOCK -->
    <div class="mock-warning" role="alert">
      &#9888; Este sitio usa datos de demostración (MOCK). Los datos mostrados son ficticios.
    </div>

    <!-- SELECTORES: ZONA HORARIA Y SELECCIÓN -->
    <section class="selectors" aria-label="Preferencias">
      <TimezoneSelector
        currentTimezone={defaultTimezone}
        locale="es"
      />
      <TeamSelector
        teams={allTeams}
        selectedTeamSlug={defaultTeamSlug}
        locale="es"
      />
    </section>

    <!-- PRÓXIMO PARTIDO DE LA SELECCIÓN -->
    <section class="next-match" aria-label="Próximo partido">
      <NextMatchCard
        match={nextMatch}
        teams={allTeams}
        timezone={defaultTimezone}
        locale="es"
      />
    </section>

    <!-- ANUNCIO -->
    <AdPlaceholder slot="middle" label="Publicidad" />

    <!-- PARTIDOS DE HOY -->
    <section class="today-matches" aria-label="Partidos de hoy">
      <h2>Partidos de Hoy</h2>
      <TodayMatches
        matches={allMatches}
        teams={allTeams}
        timezone={defaultTimezone}
        locale="es"
      />
    </section>

    <!-- PARTIDOS DE LA SELECCIÓN ELEGIDA -->
    <section class="team-matches" aria-label={`Partidos de ${teamDisplayName}`}>
      <h2>Partidos de tu Selección</h2>
      <MatchList
        matches={teamMatches}
        teams={allTeams}
        timezone={defaultTimezone}
        locale="es"
        title="Partidos de la selección"
        emptyMessage="No hay partidos confirmados disponibles para esta selección."
      />
    </section>

    <!-- COMPARTIR -->
    <section class="share" aria-label="Compartir">
      <h2>Compartir</h2>
      <ShareButtons
        locale="es"
        matchTitle="Copa del Mundo 2026"
      />
    </section>

    <!-- TEXTO SEO -->
    <section class="seo-text" aria-label="Sobre la Copa del Mundo 2026">
      <h2>Copa del Mundo 2026 &mdash; Horarios en tu zona horaria</h2>
      <p>
        La Copa del Mundo FIFA 2026 se celebrará en Estados Unidos, Canadá y México.
        Usa World Cup Games Today para seguir todos los partidos en tu horario local,
        sin convertir zonas horarias manualmente.
      </p>
      <p>
        Selecciona tu selección favorita y consulta cuándo juega &mdash; con horarios
        actualizados automáticamente para cualquier ciudad del mundo.
      </p>
    </section>

    <!-- FAQ -->
    <FAQSection
      heading="Preguntas Frecuentes"
      items={[
        {
          question: '¿Cuándo empieza el Mundial 2026?',
          answer: 'El Mundial 2026 empieza el 11 de junio de 2026 y termina el 19 de julio de 2026.',
        },
        {
          question: '¿Dónde se juega el Mundial 2026?',
          answer: 'El Mundial 2026 se jugará en tres países: Estados Unidos, Canadá y México.',
        },
        {
          question: '¿Cuántas selecciones participan en el Mundial 2026?',
          answer: 'El Mundial 2026 contará con 48 selecciones, el formato más grande en la historia del torneo.',
        },
        {
          question: '¿Cuántos partidos tendrá el Mundial 2026?',
          answer: 'El Mundial 2026 tendrá 104 partidos en total.',
        },
        {
          question: '¿Los horarios aparecen en mi zona horaria?',
          answer: 'Sí. El sitio detecta la zona horaria del navegador y permite cambiar manualmente a otra ciudad o región.',
        },
        {
          question: '¿Necesito crear una cuenta para usar el sitio?',
          answer: 'No. World Cup Games Today funciona sin inicio de sesión y sin registro.',
        },
      ]}
    />

  </div>
</BaseLayout>
