---
import type { GetStaticPaths } from 'astro';
import type { Match, Team, Group } from '../../../types/index.ts';
import matchesData from '../../../data/matches.json';
import teamsData from '../../../data/teams.json';
import groupsData from '../../../data/groups.json';
import {
  formatDate,
  formatTime,
  formatWeekday,
  isPast,
  formatCountdown,
} from '../../../utils/datetime.ts';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { buildSportsEventSchema } from '../../../utils/schema.ts';
import AdPlaceholder from '../../../components/AdPlaceholder.astro';
import ShareButtons from '../../../components/ShareButtons.astro';
import CalendarButtons from '../../../components/CalendarButtons.astro';
import LiveMatchStatus from '../../../components/LiveMatchStatus.astro';

export const getStaticPaths: GetStaticPaths = () => {
  const matches = (matchesData as { matches: Match[] }).matches;
  return matches.map((match) => ({
    params: { id: match.id },
    props: { match },
  }));
};

interface Props {
  match: Match;
}

const { match } = Astro.props;

const allTeams  = (teamsData  as { teams:  Team[]  }).teams;
const allGroups = (groupsData as { groups: Group[] }).groups;

const defaultTimezone = 'America/Mexico_City';
const locale = 'es' as const;

// Resolver nombres de selecciones (solo para confirmados)
const homeTeam = match.type === 'confirmed' && match.home_team_id
  ? allTeams.find((t) => t.id === match.home_team_id)
  : null;
const awayTeam = match.type === 'confirmed' && match.away_team_id
  ? allTeams.find((t) => t.id === match.away_team_id)
  : null;

const homeTeamName = homeTeam?.name['es'] ?? homeTeam?.name['en'] ?? homeTeam?.name['pt-br'] ?? 'A definir';
const awayTeamName = awayTeam?.name['es'] ?? awayTeam?.name['en'] ?? awayTeam?.name['pt-br'] ?? 'A definir';

// Grupo del partido (si aplica — solo cuando match.group está definido)
const matchGroup = match.group
  ? allGroups.find((g) => g.id === match.group || g.slug === match.group.toLowerCase())
  : null;
const groupName = matchGroup
  ? (matchGroup.name['es'] ?? matchGroup.name['en'] ?? matchGroup.name['pt-br'] ?? `Grupo ${matchGroup.slug.toUpperCase()}`)
  : null;

// Fecha/hora formateada — campo real es datetime_utc
const hasDate = Boolean(match.datetime_utc);
const dateFormatted    = hasDate ? formatDate(match.datetime_utc, locale, defaultTimezone)    : null;
const timeFormatted    = hasDate ? formatTime(match.datetime_utc, locale, defaultTimezone)    : null;
const weekdayFormatted = hasDate ? formatWeekday(match.datetime_utc, locale, defaultTimezone) : null;
const countdownText = hasDate && !isPast(match.datetime_utc)
  ? formatCountdown(match.datetime_utc, locale)
  : null;

// Estadio y ciudad (LocalizedString — usar 'es' con fallback 'en' y 'pt-br')
const stadiumName = match.stadium['es'] ?? match.stadium['en'] ?? match.stadium['pt-br'] ?? null;
const cityName    = match.city['es']    ?? match.city['en']    ?? match.city['pt-br']    ?? null;
const countryName = match.country['es'] ?? match.country['en'] ?? match.country['pt-br'] ?? null;

// Cadena de ubicación para el calendario ("Estadio, Ciudad, País")
const locationStr = [stadiumName, cityName, countryName].filter(Boolean).join(', ');

// Etiquetas de fase — valores exactos del tipo MatchPhase de types/index.ts
const phaseLabels: Record<string, string> = {
  'group_stage':  'Fase de Grupos',
  'round_of_32':  'Ronda de 32',
  'round_of_16':  'Octavos de Final',
  'quarterfinal': 'Cuartos de Final',
  'semifinal':    'Semifinal',
  'third_place':  'Tercer Puesto',
  'final':        'Final',
};
const phaseLabel = phaseLabels[match.phase] ?? match.phase;

// Título SEO
const matchTitle = match.type === 'confirmed'
  ? `${homeTeamName} vs ${awayTeamName} — ${phaseLabel} | Copa del Mundo 2026`
  : `${phaseLabel} — Plazas a Definir | Copa del Mundo 2026`;

// Descripción SEO
const metaDescription = match.type === 'confirmed'
  ? `Detalles del partido ${homeTeamName} vs ${awayTeamName} — ${phaseLabel} de la Copa del Mundo 2026.`
  : `${phaseLabel} de la Copa del Mundo 2026 — plazas a definir. Síguelo en World Cup Games Today.`;

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://worldcupgamestoday.com';
const canonicalUrl = `${siteUrl}/es/partidos/${match.id}`;

// Fase en inglés para el schema (estándar internacional)
const phaseLabelsEn: Record<string, string> = {
  'group_stage':  'Group Stage',
  'round_of_32':  'Round of 32',
  'round_of_16':  'Round of 16',
  'quarterfinal': 'Quarterfinal',
  'semifinal':    'Semifinal',
  'third_place':  'Third Place',
  'final':        'Final',
};
const phaseLabelEn = phaseLabelsEn[match.phase] ?? match.phase;

// Nombres de equipos en inglés para el schema (estándar internacional)
const homeTeamNameForSchema = homeTeam?.name['en'] ?? homeTeam?.name['pt-br'] ?? homeTeamName;
const awayTeamNameForSchema = awayTeam?.name['en'] ?? awayTeam?.name['pt-br'] ?? awayTeamName;

// JSON-LD SportsEvent — solo para partidos 'confirmed' con ambos equipos definidos
// 'partial' y 'simulation' NO reciben ningún schema SportsEvent (regla absoluta)
const schemaData = match.type === 'confirmed' && homeTeam && awayTeam
  ? buildSportsEventSchema({
      matchId: match.id,
      homeTeamName: homeTeamNameForSchema,
      awayTeamName: awayTeamNameForSchema,
      datetimeUtc: match.datetime_utc,
      stadiumName: match.stadium['en'] ?? match.stadium['pt-br'] ?? '',
      cityName: match.city['en'] ?? match.city['pt-br'] ?? '',
      countryName: match.country['en'] ?? match.country['pt-br'] ?? '',
      phase: phaseLabelEn,
      locale: 'en',
      canonicalUrl: canonicalUrl,
    })
  : null;

const alternates = [
  { hreflang: 'pt-BR', href: `${siteUrl}/pt-br/jogos/${match.id}` },
  { hreflang: 'en',    href: `${siteUrl}/en/matches/${match.id}` },
  { hreflang: 'es',    href: `${siteUrl}/es/partidos/${match.id}` },
];
---

<BaseLayout
  title={`${matchTitle} | World Cup Games Today`}
  description={metaDescription}
  lang="es"
  locale="es"
  canonicalUrl={canonicalUrl}
  alternates={alternates}
  ogType={match.type === 'confirmed' ? 'article' : 'website'}
>
  {schemaData && (
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} slot="head" />
  )}
  <div class="container">

    <!-- HERO DEL PARTIDO -->
    <section class="page-hero match-hero">
      {match.type === 'confirmed' ? (
        <>
          <div class="match-confronto">
            <span class="team-name home">{homeTeamName}</span>
            <span class="match-vs">&times;</span>
            <span class="team-name away">{awayTeamName}</span>
          </div>
          <p class="match-phase-label">{phaseLabel}{groupName ? ` — ${groupName}` : ''}</p>
        </>
      ) : match.type === 'partial' ? (
        <>
          <div class="match-confronto partial">
            <span class="team-name tbd">A definir</span>
            <span class="match-vs">&times;</span>
            <span class="team-name tbd">A definir</span>
          </div>
          <p class="match-phase-label">{phaseLabel} &mdash; Plazas a definir</p>
        </>
      ) : (
        <>
          <div class="match-confronto simulation">
            <span class="team-name tbd">Simulación</span>
            <span class="match-vs">&times;</span>
            <span class="team-name tbd">Simulación</span>
          </div>
          <p class="match-phase-label">{phaseLabel} &mdash; Datos de simulación</p>
        </>
      )}
    </section>

    <!-- AVISO MOCK -->
    <div class="mock-warning" role="alert">
      &#9888; Este sitio usa datos de demostración (MOCK). Los datos mostrados son ficticios.
    </div>

    <!-- AVISO ESPECIAL PARA PARCIAL -->
    {match.type === 'partial' && (
      <div class="partial-warning" role="note">
        Las selecciones de este partido aún no están definidas. Se conocerán
        a medida que avance la competición.
      </div>
    )}

    <!-- AVISO ESPECIAL PARA SIMULACIÓN -->
    {match.type === 'simulation' && (
      <div class="simulation-warning" role="note">
        Este partido es una simulación y no representa un partido real de la Copa del Mundo 2026.
      </div>
    )}

    <!-- DETALLES DEL PARTIDO -->
    <section class="match-detail-card" aria-label="Detalles del partido">
      <h2>Detalles del Partido</h2>
      <dl class="match-info-list">
        <div class="match-info-row">
          <dt>Fase</dt>
          <dd>{phaseLabel}{groupName ? ` — ${groupName}` : ''}</dd>
        </div>
        {dateFormatted && (
          <div class="match-info-row">
            <dt>Fecha</dt>
            <dd>{weekdayFormatted}, {dateFormatted}</dd>
          </div>
        )}
        {timeFormatted && (
          <div class="match-info-row">
            <dt>Hora</dt>
            <dd>{timeFormatted} (Ciudad de México)</dd>
          </div>
        )}
        {countdownText && (
          <div class="match-info-row">
            <dt>Faltan</dt>
            <dd>{countdownText}</dd>
          </div>
        )}
        {stadiumName && (
          <div class="match-info-row">
            <dt>Estadio</dt>
            <dd>{stadiumName}</dd>
          </div>
        )}
        {cityName && (
          <div class="match-info-row">
            <dt>Ciudad</dt>
            <dd>{cityName}{countryName ? `, ${countryName}` : ''}</dd>
          </div>
        )}
        <div class="match-info-row">
          <dt>Partido n.°</dt>
          <dd>{match.match_number}</dd>
        </div>
      </dl>
    </section>

    <!-- ESTADO EN VIVO — solo confirmados y parciales; simulación no se muestra -->
    {match.type !== 'simulation' && (
      <section class="live-status-section" aria-label="Estado del partido">
        <h2>Estado del Partido</h2>
        <div class="live-status-row">
          <LiveMatchStatus
            matchId={match.id}
            matchType={match.type as 'confirmed' | 'partial'}
            defaultStatus="scheduled"
            locale="es"
          />
        </div>
      </section>
    )}

    <!-- ANUNCIO (TRAS LA TARJETA DE DETALLES) -->
    <AdPlaceholder slot="middle" label="Publicidad" />

    <!-- ENLACES A LAS SELECCIONES (solo si confirmado y selecciones resueltas) -->
    {match.type === 'confirmed' && homeTeam && awayTeam && (
      <section class="match-team-links" aria-label="Selecciones en este partido">
        <h2>Selecciones</h2>
        <div class="team-links-grid">
          <a href={`/es/equipos/${homeTeam.slug}`} class="team-link-card">
            {homeTeam.flag && <span class="team-link-flag" aria-hidden="true">{homeTeam.flag}</span>}
            <span class="team-link-name">{homeTeamName}</span>
            <span class="team-link-action">Ver todos los partidos &rarr;</span>
          </a>
          <a href={`/es/equipos/${awayTeam.slug}`} class="team-link-card">
            {awayTeam.flag && <span class="team-link-flag" aria-hidden="true">{awayTeam.flag}</span>}
            <span class="team-link-name">{awayTeamName}</span>
            <span class="team-link-action">Ver todos los partidos &rarr;</span>
          </a>
        </div>
      </section>
    )}

    <!-- COMPARTIR -->
    <section class="share-section" aria-label="Compartir">
      <h2>Compartir</h2>
      <ShareButtons
        locale="es"
        matchType={match.type as 'confirmed' | 'partial' | 'simulation'}
        homeTeamName={match.type === 'confirmed' ? homeTeamName : undefined}
        awayTeamName={match.type === 'confirmed' ? awayTeamName : undefined}
        dateFormatted={weekdayFormatted && dateFormatted ? `${weekdayFormatted}, ${dateFormatted}` : dateFormatted ?? undefined}
        timeFormatted={timeFormatted ?? undefined}
        pageUrl={`${import.meta.env.PUBLIC_SITE_URL || 'https://worldcupgamestoday.com'}/es/partidos/${match.id}`}
      />
    </section>

    <!-- AGREGAR AL CALENDARIO (solo confirmados y parciales — simulación no se muestra) -->
    {match.type !== 'simulation' && (
      <section class="calendar-section" aria-label="Agregar al calendario">
        <h2>Agregar al Calendario</h2>
        <CalendarButtons
          matchId={match.id}
          matchType={match.type as 'confirmed' | 'partial'}
          homeTeamName={match.type === 'confirmed' ? homeTeamName : undefined}
          awayTeamName={match.type === 'confirmed' ? awayTeamName : undefined}
          datetimeUtc={match.datetime_utc}
          locationStr={locationStr}
          pageUrl={`${import.meta.env.PUBLIC_SITE_URL || 'https://worldcupgamestoday.com'}/es/partidos/${match.id}`}
          locale="es"
        />
      </section>
    )}

    <!-- ENLACES INTERNOS -->
    <nav class="internal-links" aria-label="Navegación interna">
      <ul>
        <li><a href="/es/">&larr; Inicio</a></li>
        <li><a href="/es/calendario-mundial-2026">Calendario del Mundial 2026</a></li>
        <li><a href="/es/partidos-de-hoy-mundial">Partidos de Hoy</a></li>
        {groupName && matchGroup && (
          <li><a href={`/es/grupos/${matchGroup.slug}`}>Ver {groupName}</a></li>
        )}
      </ul>
    </nav>

    <!-- TEXTO SEO -->
    <section class="seo-text">
      {match.type === 'confirmed' ? (
        <>
          <h2>{homeTeamName} vs {awayTeamName} &mdash; Copa del Mundo 2026</h2>
          <p>
            Sigue todos los detalles del partido {homeTeamName} vs {awayTeamName}
            en la {phaseLabel} de la Copa del Mundo FIFA 2026. Hora de inicio mostrada en tu zona horaria local.
          </p>
        </>
      ) : (
        <>
          <h2>{phaseLabel} &mdash; Copa del Mundo 2026</h2>
          <p>
            Sigue los detalles de esta fase de la Copa del Mundo FIFA 2026.
            Las selecciones se determinarán a medida que avance la competición.
          </p>
        </>
      )}
    </section>

  </div>
</BaseLayout>

<style>
  /* ===== HERO DEL PARTIDO ===== */

  .match-hero {
    text-align: center;
    padding: var(--space-8) 0;
  }

  .match-confronto {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-2);
  }

  .team-name {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
  }

  .team-name.tbd {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .match-vs {
    font-size: var(--font-size-xl);
    color: var(--color-text-muted);
    font-weight: var(--font-weight-normal);
    flex-shrink: 0;
  }

  .match-phase-label {
    margin-top: var(--space-2);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    margin-bottom: 0;
  }

  /* ===== AVISOS (parcial / simulación) ===== */

  .partial-warning,
  .simulation-warning {
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-6);
    line-height: var(--line-height-relaxed);
  }

  .partial-warning {
    background: var(--color-scheduled-bg);
    border: 1px solid var(--color-scheduled);
    color: var(--color-scheduled);
  }

  .simulation-warning {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  /* ===== TARJETA DE DETALLES ===== */

  .match-detail-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .match-detail-card h2 {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin-bottom: var(--space-5);
  }

  .match-info-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin: 0;
  }

  .match-info-row {
    display: flex;
    gap: var(--space-4);
    align-items: baseline;
  }

  .match-info-row dt {
    font-weight: var(--font-weight-semibold);
    min-width: 80px;
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    flex-shrink: 0;
  }

  .match-info-row dd {
    margin: 0;
    font-size: var(--font-size-base);
    color: var(--color-text);
  }

  /* ===== ENLACES A SELECCIONES ===== */

  .match-team-links {
    margin-bottom: var(--space-8);
  }

  .match-team-links h2 {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .team-links-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .team-link-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    background-color: var(--color-bg-card);
  }

  .team-link-card:hover,
  .team-link-card:focus {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
  }

  .team-link-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .team-link-flag {
    font-size: var(--font-size-xl);
    line-height: 1;
  }

  .team-link-name {
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    font-size: var(--font-size-base);
  }

  .team-link-action {
    font-size: var(--font-size-sm);
    color: var(--color-accent);
  }

  /* ===== ENLACES INTERNOS ===== */

  .internal-links {
    margin-block: var(--space-8);
    padding: var(--space-5) var(--space-6);
    background-color: var(--color-bg-alt);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-light);
  }

  .internal-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .internal-links a {
    color: var(--color-text);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .internal-links a:hover,
  .internal-links a:focus {
    color: var(--color-accent);
    text-decoration: underline;
  }

  /* ===== COMPARTIR ===== */

  .share-section {
    margin-block: var(--space-6);
    padding: var(--space-6);
    background-color: var(--color-bg-alt);
    border-radius: var(--radius-lg);
  }

  .share-section h2 {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  /* ===== ESTADO EN VIVO ===== */

  .live-status-section {
    margin-bottom: var(--space-6);
    padding: var(--space-5) var(--space-6);
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .live-status-section h2 {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .live-status-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* ===== CALENDARIO ===== */

  .calendar-section {
    margin-block: var(--space-6);
    padding: var(--space-6);
    background-color: var(--color-bg-alt);
    border-radius: var(--radius-lg);
  }

  .calendar-section h2 {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  /* ===== RESPONSIVIDAD ===== */

  @media (min-width: 480px) {
    .internal-links ul {
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--space-3) var(--space-6);
    }
  }

  @media (max-width: 480px) {
    .team-links-grid {
      grid-template-columns: 1fr;
    }

    .team-name {
      font-size: var(--font-size-xl);
    }

    .match-detail-card {
      padding: var(--space-4);
    }
  }

  @media (min-width: 768px) {
    .match-detail-card h2,
    .match-team-links h2,
    .share-section h2 {
      font-size: var(--font-size-2xl);
    }

    .team-name {
      font-size: var(--font-size-3xl);
    }

    .match-vs {
      font-size: var(--font-size-2xl);
    }
  }
</style>
