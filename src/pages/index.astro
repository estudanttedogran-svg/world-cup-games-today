---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="World Cup Games Today — Copa do Mundo 2026"
  lang="en"
  locale="en"
>
  <section style="padding: var(--space-16) var(--space-4); text-align: center;">
    <h1 style="margin-bottom: var(--space-4);">World Cup Games Today</h1>
    <p style="font-size: var(--font-size-lg); color: var(--color-text-muted); margin-bottom: var(--space-8);">
      See every World Cup 2026 match in your local time.
    </p>
    <nav aria-label="Language selection" style="display: flex; justify-content: center; gap: var(--space-4); flex-wrap: wrap;">
      <a href="/pt-br/" style="padding: var(--space-3) var(--space-6); background: var(--color-primary); color: #fff; border-radius: var(--radius-md); font-weight: var(--font-weight-semibold); text-decoration: none;">
        Português (Brasil)
      </a>
      <a href="/en/" style="padding: var(--space-3) var(--space-6); background: var(--color-accent); color: #fff; border-radius: var(--radius-md); font-weight: var(--font-weight-semibold); text-decoration: none;">
        English
      </a>
      <a href="/es/" style="padding: var(--space-3) var(--space-6); background: var(--color-primary); color: #fff; border-radius: var(--radius-md); font-weight: var(--font-weight-semibold); text-decoration: none;">
        Español
      </a>
    </nav>
  </section>
</BaseLayout>
