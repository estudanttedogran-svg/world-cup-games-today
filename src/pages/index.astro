---
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://worldcupgamestoday.com';
const canonicalUrl = `${siteUrl}/`;
const alternates = [
  { hreflang: 'x-default', href: `${siteUrl}/` },
  { hreflang: 'pt-BR',     href: `${siteUrl}/pt-br/` },
  { hreflang: 'en',        href: `${siteUrl}/en/` },
  { hreflang: 'es',        href: `${siteUrl}/es/` },
];
---

<BaseLayout
  title="World Cup Games Today 2026"
  description="See every World Cup 2026 match schedule in your local time. Choose your language to get started."
  lang="en"
  locale="en"
  canonicalUrl={canonicalUrl}
  alternates={alternates}
>
  <div class="lang-select-page">
    <div class="container">

      <!-- Hero -->
      <header class="lang-hero">
        <div class="lang-hero__icon" aria-hidden="true">&#9917;</div>
        <h1 class="lang-hero__title">World Cup Games Today</h1>
        <p class="lang-hero__tagline">
          See every World Cup 2026 match in your local time.
        </p>
      </header>

      <!-- Sugestão automática (oculta por padrão, exibida pelo script) -->
      <div id="lang-suggestion" class="lang-suggestion" aria-live="polite" hidden>
        <span class="lang-suggestion__text" id="lang-suggestion-text"></span>
        <a href="#" id="lang-suggestion-link" class="lang-suggestion__link"></a>
      </div>

      <!-- Cards de seleção de idioma -->
      <nav aria-label="Language selection" class="lang-cards">

        <a
          href="/pt-br/"
          class="lang-card"
          data-lang="pt-br"
          hreflang="pt-BR"
          aria-label="Acessar versão em Português (Brasil)"
        >
          <span class="lang-card__flag" aria-hidden="true">&#127463;&#127479;</span>
          <span class="lang-card__name">Português</span>
          <span class="lang-card__region">(Brasil)</span>
          <span class="lang-card__arrow" aria-hidden="true">&#8594;</span>
        </a>

        <a
          href="/en/"
          class="lang-card"
          data-lang="en"
          hreflang="en"
          aria-label="Go to the English version"
        >
          <span class="lang-card__flag" aria-hidden="true">&#127468;&#127463;</span>
          <span class="lang-card__name">English</span>
          <span class="lang-card__region">(Global)</span>
          <span class="lang-card__arrow" aria-hidden="true">&#8594;</span>
        </a>

        <a
          href="/es/"
          class="lang-card"
          data-lang="es"
          hreflang="es"
          aria-label="Ir a la versión en Español"
        >
          <span class="lang-card__flag" aria-hidden="true">&#127466;&#127480;</span>
          <span class="lang-card__name">Español</span>
          <span class="lang-card__region">(Latinoamérica)</span>
          <span class="lang-card__arrow" aria-hidden="true">&#8594;</span>
        </a>

      </nav>

      <!-- Nota sobre dados de demonstração -->
      <p class="lang-demo-note">
        Data shown is for demonstration purposes only.
      </p>

    </div>
  </div>
</BaseLayout>

<script>
  // Guard: só executa no browser
  if (typeof window !== 'undefined' && typeof navigator !== 'undefined') {
    (function () {
      // --- Detecta idioma preferido do navegador ---
      function detectLocale() {
        try {
          var langs = (navigator.languages && navigator.languages.length > 0)
            ? Array.from(navigator.languages)
            : [navigator.language || 'en'];

          for (var i = 0; i < langs.length; i++) {
            var l = langs[i].toLowerCase();
            if (l.startsWith('pt')) return 'pt-br';
            if (l.startsWith('es')) return 'es';
            if (l.startsWith('en')) return 'en';
          }
          return 'en';
        } catch (e) {
          return 'en';
        }
      }

      // --- Lê preferência salva em wcgt_lang ---
      function getSavedLang() {
        try {
          if (typeof localStorage === 'undefined') return null;
          var val = localStorage.getItem('wcgt_lang');
          if (val === 'pt-br' || val === 'en' || val === 'es') return val;
          return null;
        } catch (e) {
          return null;
        }
      }

      // --- Salva preferência em wcgt_lang ao clicar num card ---
      var cards = document.querySelectorAll('.lang-card');
      for (var ci = 0; ci < cards.length; ci++) {
        cards[ci].addEventListener('click', function () {
          try {
            if (typeof localStorage !== 'undefined') {
              var lang = this.getAttribute('data-lang');
              if (lang) localStorage.setItem('wcgt_lang', lang);
            }
          } catch (e) {
            // localStorage indisponível — ignorar silenciosamente
          }
        });
      }

      // --- Monta a sugestão automática ---
      var locale = getSavedLang() || detectLocale();

      var suggestions = {
        'pt-br': {
          text: 'Parece que você fala Português — ',
          linkText: 'Ir para a versão em Português →',
          href: '/pt-br/'
        },
        'en': {
          text: 'Looks like you speak English — ',
          linkText: 'Go to the English version →',
          href: '/en/'
        },
        'es': {
          text: 'Parece que hablas Español — ',
          linkText: 'Ir a la versión en Español →',
          href: '/es/'
        }
      };

      var suggestion = suggestions[locale];
      if (suggestion) {
        var container = document.getElementById('lang-suggestion');
        var textEl = document.getElementById('lang-suggestion-text');
        var linkEl = document.getElementById('lang-suggestion-link');

        if (container && textEl && linkEl) {
          textEl.textContent = suggestion.text;
          linkEl.textContent = suggestion.linkText;
          linkEl.setAttribute('href', suggestion.href);
          container.removeAttribute('hidden');
        }
      }
    })();
  }
</script>

<style>
  /* ===== PÁGINA DE SELEÇÃO DE IDIOMA ===== */

  .lang-select-page {
    min-height: calc(100vh - var(--header-height) - 200px);
    display: flex;
    align-items: center;
    padding-block: var(--space-12) var(--space-10);
  }

  .lang-select-page .container {
    width: 100%;
  }

  /* Hero */
  .lang-hero {
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .lang-hero__icon {
    font-size: 3rem;
    line-height: 1;
    margin-bottom: var(--space-4);
    display: block;
  }

  .lang-hero__title {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
    margin-bottom: var(--space-3);
    line-height: var(--line-height-tight);
  }

  .lang-hero__tagline {
    font-size: var(--font-size-lg);
    color: var(--color-text-muted);
    max-width: 50ch;
    margin-inline: auto;
    line-height: var(--line-height-relaxed);
  }

  @media (min-width: 768px) {
    .lang-hero__title {
      font-size: var(--font-size-3xl);
    }

    .lang-hero__icon {
      font-size: 4rem;
    }
  }

  /* Sugestão automática */
  .lang-suggestion {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-1);
    margin-bottom: var(--space-6);
    padding: var(--space-3) var(--space-4);
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    max-width: 640px;
    margin-inline: auto;
  }

  .lang-suggestion__text {
    color: var(--color-text-muted);
  }

  .lang-suggestion__link {
    color: var(--color-accent);
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .lang-suggestion__link:hover,
  .lang-suggestion__link:focus {
    color: var(--color-accent-hover);
    text-decoration: underline;
  }

  /* Cards de idioma */
  .lang-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: var(--space-8);
  }

  @media (min-width: 480px) {
    .lang-cards {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  .lang-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-6) var(--space-4);
    background-color: var(--color-bg-card);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-text);
    box-shadow: var(--shadow-sm);
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base),
      transform var(--transition-base);
    cursor: pointer;
  }

  /* Mobile: horizontal layout */
  @media (max-width: 479px) {
    .lang-card {
      flex-direction: row;
      justify-content: flex-start;
      padding: var(--space-4) var(--space-5);
    }

    .lang-card__arrow {
      margin-left: auto;
    }
  }

  .lang-card:hover,
  .lang-card:focus-visible {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
    color: var(--color-text);
  }

  .lang-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .lang-card__flag {
    font-size: 2rem;
    line-height: 1;
  }

  .lang-card__name {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
  }

  .lang-card__region {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  .lang-card__arrow {
    font-size: var(--font-size-lg);
    color: var(--color-accent);
    line-height: 1;
  }

  /* Nota de demonstração */
  .lang-demo-note {
    text-align: center;
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-2);
  }
</style>
