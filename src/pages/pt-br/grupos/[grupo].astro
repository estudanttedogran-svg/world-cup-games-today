---
import type { GetStaticPaths } from 'astro';
import type { Match, Team, Group, StandingEntry } from '../../../types/index.ts';
import groupsData from '../../../data/groups.json';
import matchesData from '../../../data/matches.json';
import teamsData from '../../../data/teams.json';
import { sortMatchesByDate } from '../../../utils/matches.ts';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GroupTable from '../../../components/GroupTable.astro';
import MatchList from '../../../components/MatchList.astro';
import AdPlaceholder from '../../../components/AdPlaceholder.astro';
import ShareButtons from '../../../components/ShareButtons.astro';

export const getStaticPaths: GetStaticPaths = () => {
  const groups = (groupsData as { groups: Group[] }).groups;
  return groups.map((group) => ({
    params: { grupo: group.slug },
    props: { group },
  }));
};

interface Props {
  group: Group;
}

const { group } = Astro.props;

const allMatches = (matchesData as { matches: Match[] }).matches;
const allTeams   = (teamsData  as { teams:   Team[]  }).teams;

const defaultTimezone = 'America/Sao_Paulo';
const locale = 'pt-br' as const;

// Times do grupo — group.team_ids contém slugs que correspondem a team.id (e team.slug)
const groupTeams = allTeams.filter((t) => group.team_ids.includes(t.id));

// Nome do grupo no locale
const groupName = group.name['pt-br'] ?? group.name['en'] ?? `Grupo ${group.slug.toUpperCase()}`;

// Jogos confirmados do grupo — partidas em que pelo menos um dos times está no grupo
const groupTeamIds = group.team_ids;
const confirmedGroupMatches = sortMatchesByDate(
  allMatches.filter(
    (m) =>
      m.type === 'confirmed' &&
      (
        (m.home_team_id !== null && groupTeamIds.includes(m.home_team_id)) ||
        (m.away_team_id !== null && groupTeamIds.includes(m.away_team_id))
      )
  )
);

// MOCK standings — mesmos dados usados em tabela-copa-2026.astro
// Campos seguem o tipo StandingEntry (snake_case): team_id, played, won, drawn, lost, goals_for, goals_against, points
const mockStandingsMap: Record<string, StandingEntry[]> = {
  'm': [
    { team_id: 'northland', played: 2, won: 1, drawn: 1, lost: 0, goals_for: 3, goals_against: 1, points: 4 },
    { team_id: 'eastoria',  played: 2, won: 1, drawn: 0, lost: 1, goals_for: 1, goals_against: 2, points: 3 },
    { team_id: 'westmark',  played: 1, won: 0, drawn: 1, lost: 0, goals_for: 0, goals_against: 0, points: 1 },
    { team_id: 'southmore', played: 1, won: 0, drawn: 0, lost: 1, goals_for: 1, goals_against: 2, points: 0 },
  ],
  'n': [
    { team_id: 'highpeak',  played: 1, won: 1, drawn: 0, lost: 0, goals_for: 1, goals_against: 0, points: 3 },
    { team_id: 'lowvale',   played: 0, won: 0, drawn: 0, lost: 0, goals_for: 0, goals_against: 0, points: 0 },
    { team_id: 'bayshore',  played: 1, won: 0, drawn: 0, lost: 1, goals_for: 0, goals_against: 1, points: 0 },
    { team_id: 'ridgemont', played: 0, won: 0, drawn: 0, lost: 0, goals_for: 0, goals_against: 0, points: 0 },
  ],
};
const groupStandings: StandingEntry[] = mockStandingsMap[group.slug] ?? [];
---

<BaseLayout
  title={`${groupName} — Tabela e Jogos | Copa do Mundo 2026 | World Cup Games Today`}
  description={`Veja a classificação e todos os jogos do ${groupName} da Copa do Mundo 2026 com horários no seu fuso local.`}
  lang="pt-BR"
  locale="pt-br"
>
  <div class="container">

    <!-- HERO DO GRUPO -->
    <section class="page-hero">
      <h1>{groupName}</h1>
      <p>Classificação e jogos do {groupName} da Copa do Mundo 2026.</p>
    </section>

    <!-- AVISO DE DADOS MOCK -->
    <div class="mock-warning" role="alert">
      &#9888; Este site usa dados de demonstração (MOCK). Os dados exibidos são fictícios.
    </div>

    <!-- TABELA DE CLASSIFICAÇÃO -->
    <section class="group-table-section" aria-label={`Classificação — ${groupName}`}>
      <h2>Classificação &mdash; {groupName}</h2>
      <GroupTable
        group={group}
        standings={groupStandings}
        teams={allTeams}
        locale="pt-br"
      />
    </section>

    <!-- SELEÇÕES DO GRUPO -->
    <section class="group-teams-section" aria-label={`Seleções do ${groupName}`}>
      <h2>Seleções do {groupName}</h2>
      <ul class="group-teams-list" role="list">
        {groupTeams.map((team) => (
          <li>
            <a href={`/pt-br/selecoes/${team.slug}`}>
              {team.flag && <span aria-hidden="true">{team.flag}</span>}
              {team.name['pt-br'] ?? team.name['en'] ?? team.slug}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- JOGOS CONFIRMADOS DO GRUPO -->
    <section class="group-matches-section" aria-label={`Jogos do ${groupName}`}>
      <h2>Jogos do {groupName}</h2>
      <MatchList
        matches={confirmedGroupMatches}
        teams={allTeams}
        timezone={defaultTimezone}
        locale="pt-br"
        emptyMessage="Nenhum jogo confirmado disponível para este grupo."
      />
    </section>

    <!-- ANÚNCIO (APÓS O CONTEÚDO PRINCIPAL) -->
    <AdPlaceholder slot="bottom" label="Anúncio" />

    <!-- LINKS INTERNOS -->
    <nav class="internal-links" aria-label="Navegação interna">
      <h2>Veja também</h2>
      <ul>
        <li><a href="/pt-br/">Home &mdash; Copa 2026</a></li>
        <li><a href="/pt-br/jogos-de-hoje-copa">Jogos de hoje</a></li>
        <li><a href="/pt-br/tabela-copa-2026">Tabela completa da Copa 2026</a></li>
      </ul>
    </nav>

    <!-- BOTÕES DE COMPARTILHAMENTO -->
    <section class="share-section" aria-label="Compartilhar">
      <h2>Compartilhe</h2>
      <ShareButtons
        locale="pt-br"
        matchTitle={`${groupName} — Copa do Mundo 2026`}
      />
    </section>

    <!-- TEXTO SEO -->
    <section class="seo-text" aria-label={`${groupName} na Copa do Mundo 2026`}>
      <h2>{groupName} da Copa do Mundo 2026</h2>
      <p>
        Acompanhe a tabela de classificação e todos os jogos do {groupName}
        da Copa do Mundo FIFA 2026. Os horários são exibidos automaticamente
        no seu fuso horário local.
      </p>
      <p>
        Use o World Cup Games Today para saber quando as seleções do {groupName}
        jogam &mdash; com horário atualizado para qualquer cidade do mundo.
      </p>
    </section>

  </div>
</BaseLayout>

<style>
  /* Tabela de classificação do grupo */
  .group-table-section {
    margin-bottom: var(--space-10);
  }

  .group-table-section h2 {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin-bottom: var(--space-6);
  }

  /* Seleções do grupo */
  .group-teams-section {
    margin-bottom: var(--space-10);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border-light);
  }

  .group-teams-section h2 {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  /* Lista de seleções — sem bullet, flex wrap */
  .group-teams-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .group-teams-list li {
    display: flex;
  }

  .group-teams-list a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text);
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: background-color var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast);
  }

  .group-teams-list a:hover,
  .group-teams-list a:focus {
    background-color: var(--color-bg-alt);
    border-color: var(--color-accent);
    color: var(--color-accent);
    text-decoration: none;
  }

  .group-teams-list a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* Jogos do grupo */
  .group-matches-section {
    margin-bottom: var(--space-10);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border-light);
  }

  .group-matches-section h2 {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin-bottom: var(--space-6);
  }

  /* Links internos */
  .internal-links {
    margin-block: var(--space-8);
    padding: var(--space-5) var(--space-6);
    background-color: var(--color-bg-alt);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-light);
  }

  .internal-links h2 {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-3);
  }

  .internal-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .internal-links a {
    color: var(--color-text);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .internal-links a:hover,
  .internal-links a:focus {
    color: var(--color-accent);
    text-decoration: underline;
  }

  /* Responsividade */
  @media (min-width: 480px) {
    .internal-links ul {
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--space-3) var(--space-6);
    }
  }

  @media (min-width: 768px) {
    .group-table-section h2,
    .group-teams-section h2,
    .group-matches-section h2 {
      font-size: var(--font-size-2xl);
    }
  }
</style>
