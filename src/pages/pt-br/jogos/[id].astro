---
import type { GetStaticPaths } from 'astro';
import type { Match, Team, Group } from '../../../types/index.ts';
import matchesData from '../../../data/matches.json';
import teamsData from '../../../data/teams.json';
import groupsData from '../../../data/groups.json';
import {
  formatDate,
  formatTime,
  formatWeekday,
  isPast,
  formatCountdown,
} from '../../../utils/datetime.ts';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AdPlaceholder from '../../../components/AdPlaceholder.astro';
import ShareButtons from '../../../components/ShareButtons.astro';

export const getStaticPaths: GetStaticPaths = () => {
  const matches = (matchesData as { matches: Match[] }).matches;
  return matches.map((match) => ({
    params: { id: match.id },
    props: { match },
  }));
};

interface Props {
  match: Match;
}

const { match } = Astro.props;

const allTeams  = (teamsData  as { teams:  Team[]  }).teams;
const allGroups = (groupsData as { groups: Group[] }).groups;

const defaultTimezone = 'America/Sao_Paulo';
const locale = 'pt-br' as const;

// Resolver nomes dos times (somente para confirmed)
const homeTeam = match.type === 'confirmed' && match.home_team_id
  ? allTeams.find((t) => t.id === match.home_team_id)
  : null;
const awayTeam = match.type === 'confirmed' && match.away_team_id
  ? allTeams.find((t) => t.id === match.away_team_id)
  : null;

const homeTeamName = homeTeam?.name['pt-br'] ?? homeTeam?.name['en'] ?? 'A definir';
const awayTeamName = awayTeam?.name['pt-br'] ?? awayTeam?.name['en'] ?? 'A definir';

// Grupo da partida (se aplicável — somente quando match.group definido)
const matchGroup = match.group
  ? allGroups.find((g) => g.id === match.group || g.slug === match.group.toLowerCase())
  : null;
const groupName = matchGroup
  ? (matchGroup.name['pt-br'] ?? matchGroup.name['en'] ?? `Grupo ${matchGroup.slug.toUpperCase()}`)
  : null;

// Data/hora formatada — campo real é datetime_utc
const hasDate = Boolean(match.datetime_utc);
const dateFormatted    = hasDate ? formatDate(match.datetime_utc, locale, defaultTimezone)    : null;
const timeFormatted    = hasDate ? formatTime(match.datetime_utc, locale, defaultTimezone)    : null;
const weekdayFormatted = hasDate ? formatWeekday(match.datetime_utc, locale, defaultTimezone) : null;
const countdownText = hasDate && !isPast(match.datetime_utc)
  ? formatCountdown(match.datetime_utc, locale)
  : null;

// Estádio e cidade (LocalizedString — usar locale pt-br com fallback en)
const stadiumName = match.stadium['pt-br'] ?? match.stadium['en'] ?? null;
const cityName    = match.city['pt-br']    ?? match.city['en']    ?? null;
const countryName = match.country['pt-br'] ?? match.country['en'] ?? null;

// Rótulo da fase — segue os valores exatos do tipo MatchPhase em types/index.ts
const phaseLabels: Record<string, string> = {
  'group_stage':  'Fase de Grupos',
  'round_of_32':  'Rodada de 32',
  'round_of_16':  'Oitavas de Final',
  'quarterfinal': 'Quartas de Final',
  'semifinal':    'Semifinal',
  'third_place':  'Disputa de 3º Lugar',
  'final':        'Final',
};
const phaseLabel = phaseLabels[match.phase] ?? match.phase;

// Título SEO
const matchTitle = match.type === 'confirmed'
  ? `${homeTeamName} x ${awayTeamName} — ${phaseLabel} | Copa 2026`
  : `${phaseLabel} — Vagas a Definir | Copa 2026`;

// Descrição SEO
const metaDescription = match.type === 'confirmed'
  ? `Veja detalhes de ${homeTeamName} x ${awayTeamName} — ${phaseLabel} da Copa do Mundo 2026.`
  : `${phaseLabel} da Copa do Mundo 2026 — vagas a definir. Acompanhe no World Cup Games Today.`;
---

<BaseLayout
  title={`${matchTitle} | World Cup Games Today`}
  description={metaDescription}
  lang="pt-BR"
  locale="pt-br"
>
  <div class="container">

    <!-- HERO DA PARTIDA -->
    <section class="page-hero match-hero">
      {match.type === 'confirmed' ? (
        <>
          <div class="match-confronto">
            <span class="team-name home">{homeTeamName}</span>
            <span class="match-vs">&times;</span>
            <span class="team-name away">{awayTeamName}</span>
          </div>
          <p class="match-phase-label">{phaseLabel}{groupName ? ` — ${groupName}` : ''}</p>
        </>
      ) : match.type === 'partial' ? (
        <>
          <div class="match-confronto partial">
            <span class="team-name tbd">A definir</span>
            <span class="match-vs">&times;</span>
            <span class="team-name tbd">A definir</span>
          </div>
          <p class="match-phase-label">{phaseLabel} &mdash; Vagas a definir</p>
        </>
      ) : (
        <>
          <div class="match-confronto simulation">
            <span class="team-name tbd">Simula&ccedil;&atilde;o</span>
            <span class="match-vs">&times;</span>
            <span class="team-name tbd">Simula&ccedil;&atilde;o</span>
          </div>
          <p class="match-phase-label">{phaseLabel} &mdash; Dado de simula&ccedil;&atilde;o</p>
        </>
      )}
    </section>

    <!-- AVISO MOCK -->
    <div class="mock-warning" role="alert">
      &#9888; Este site usa dados de demonstra&ccedil;&atilde;o (MOCK). Os dados exibidos s&atilde;o fict&iacute;cios.
    </div>

    <!-- AVISO ESPECIAL PARA PARTIAL -->
    {match.type === 'partial' && (
      <div class="partial-warning" role="note">
        As sele&ccedil;&otilde;es desta partida ainda n&atilde;o foram definidas. Os times ser&atilde;o conhecidos
        ao longo da competi&ccedil;&atilde;o.
      </div>
    )}

    <!-- AVISO ESPECIAL PARA SIMULATION -->
    {match.type === 'simulation' && (
      <div class="simulation-warning" role="note">
        Este jogo &eacute; uma simula&ccedil;&atilde;o e n&atilde;o representa uma partida real da Copa 2026.
      </div>
    )}

    <!-- CARD DE DETALHES DA PARTIDA -->
    <section class="match-detail-card" aria-label="Detalhes da partida">
      <h2>Detalhes da Partida</h2>
      <dl class="match-info-list">
        <div class="match-info-row">
          <dt>Fase</dt>
          <dd>{phaseLabel}{groupName ? ` — ${groupName}` : ''}</dd>
        </div>
        {dateFormatted && (
          <div class="match-info-row">
            <dt>Data</dt>
            <dd>{weekdayFormatted}, {dateFormatted}</dd>
          </div>
        )}
        {timeFormatted && (
          <div class="match-info-row">
            <dt>Hor&aacute;rio</dt>
            <dd>{timeFormatted} (S&atilde;o Paulo)</dd>
          </div>
        )}
        {countdownText && (
          <div class="match-info-row">
            <dt>Faltam</dt>
            <dd>{countdownText}</dd>
          </div>
        )}
        {stadiumName && (
          <div class="match-info-row">
            <dt>Est&aacute;dio</dt>
            <dd>{stadiumName}</dd>
          </div>
        )}
        {cityName && (
          <div class="match-info-row">
            <dt>Cidade</dt>
            <dd>{cityName}{countryName ? `, ${countryName}` : ''}</dd>
          </div>
        )}
        <div class="match-info-row">
          <dt>Jogo n&ordm;</dt>
          <dd>{match.match_number}</dd>
        </div>
      </dl>
    </section>

    <!-- ANÚNCIO (APÓS O CARD DE DETALHES) -->
    <AdPlaceholder slot="middle" label="An&uacute;ncio" />

    <!-- LINKS PARA SELEÇÕES (somente se confirmed e times resolvidos) -->
    {match.type === 'confirmed' && homeTeam && awayTeam && (
      <section class="match-team-links" aria-label="Seleções desta partida">
        <h2>Sele&ccedil;&otilde;es</h2>
        <div class="team-links-grid">
          <a href={`/pt-br/selecoes/${homeTeam.slug}`} class="team-link-card">
            {homeTeam.flag && <span class="team-link-flag" aria-hidden="true">{homeTeam.flag}</span>}
            <span class="team-link-name">{homeTeamName}</span>
            <span class="team-link-action">Ver todos os jogos &rarr;</span>
          </a>
          <a href={`/pt-br/selecoes/${awayTeam.slug}`} class="team-link-card">
            {awayTeam.flag && <span class="team-link-flag" aria-hidden="true">{awayTeam.flag}</span>}
            <span class="team-link-name">{awayTeamName}</span>
            <span class="team-link-action">Ver todos os jogos &rarr;</span>
          </a>
        </div>
      </section>
    )}

    <!-- COMPARTILHE -->
    <section class="share-section" aria-label="Compartilhar">
      <h2>Compartilhe</h2>
      <ShareButtons
        locale="pt-br"
        matchTitle={matchTitle}
        matchId={match.id}
      />
    </section>

    <!-- LINKS INTERNOS -->
    <nav class="internal-links" aria-label="Navega&ccedil;&atilde;o interna">
      <ul>
        <li><a href="/pt-br/">&larr; Home</a></li>
        <li><a href="/pt-br/tabela-copa-2026">Tabela da Copa 2026</a></li>
        <li><a href="/pt-br/jogos-de-hoje-copa">Jogos de hoje</a></li>
        {groupName && matchGroup && (
          <li><a href={`/pt-br/grupos/${matchGroup.slug}`}>Ver {groupName}</a></li>
        )}
      </ul>
    </nav>

    <!-- TEXTO SEO -->
    <section class="seo-text">
      {match.type === 'confirmed' ? (
        <>
          <h2>{homeTeamName} x {awayTeamName} &mdash; Copa 2026</h2>
          <p>
            Acompanhe todos os detalhes de {homeTeamName} x {awayTeamName}
            pela {phaseLabel} da Copa do Mundo FIFA 2026. Hor&aacute;rio exibido no seu fuso local.
          </p>
        </>
      ) : (
        <>
          <h2>{phaseLabel} &mdash; Copa do Mundo 2026</h2>
          <p>
            Acompanhe os detalhes desta fase da Copa do Mundo FIFA 2026.
            As sele&ccedil;&otilde;es ser&atilde;o definidas ao longo da competi&ccedil;&atilde;o.
          </p>
        </>
      )}
    </section>

  </div>
</BaseLayout>

<style>
  /* ===== HERO DA PARTIDA ===== */

  .match-hero {
    text-align: center;
    padding: var(--space-8) 0;
  }

  .match-confronto {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-2);
  }

  .team-name {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
  }

  .team-name.tbd {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .match-vs {
    font-size: var(--font-size-xl);
    color: var(--color-text-muted);
    font-weight: var(--font-weight-normal);
    flex-shrink: 0;
  }

  .match-phase-label {
    margin-top: var(--space-2);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    margin-bottom: 0;
  }

  /* ===== AVISOS (partial / simulation) ===== */

  .partial-warning,
  .simulation-warning {
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-6);
    line-height: var(--line-height-relaxed);
  }

  .partial-warning {
    background: var(--color-scheduled-bg);
    border: 1px solid var(--color-scheduled);
    color: var(--color-scheduled);
  }

  .simulation-warning {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  /* ===== CARD DE DETALHES ===== */

  .match-detail-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .match-detail-card h2 {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin-bottom: var(--space-5);
  }

  .match-info-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin: 0;
  }

  .match-info-row {
    display: flex;
    gap: var(--space-4);
    align-items: baseline;
  }

  .match-info-row dt {
    font-weight: var(--font-weight-semibold);
    min-width: 80px;
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    flex-shrink: 0;
  }

  .match-info-row dd {
    margin: 0;
    font-size: var(--font-size-base);
    color: var(--color-text);
  }

  /* ===== LINKS PARA SELEÇÕES ===== */

  .match-team-links {
    margin-bottom: var(--space-8);
  }

  .match-team-links h2 {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .team-links-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .team-link-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    background-color: var(--color-bg-card);
  }

  .team-link-card:hover,
  .team-link-card:focus {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
  }

  .team-link-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .team-link-flag {
    font-size: var(--font-size-xl);
    line-height: 1;
  }

  .team-link-name {
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    font-size: var(--font-size-base);
  }

  .team-link-action {
    font-size: var(--font-size-sm);
    color: var(--color-accent);
  }

  /* ===== LINKS INTERNOS ===== */

  .internal-links {
    margin-block: var(--space-8);
    padding: var(--space-5) var(--space-6);
    background-color: var(--color-bg-alt);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-light);
  }

  .internal-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .internal-links a {
    color: var(--color-text);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .internal-links a:hover,
  .internal-links a:focus {
    color: var(--color-accent);
    text-decoration: underline;
  }

  /* ===== COMPARTILHAMENTO ===== */

  .share-section {
    margin-block: var(--space-6);
    padding: var(--space-6);
    background-color: var(--color-bg-alt);
    border-radius: var(--radius-lg);
  }

  .share-section h2 {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  /* ===== RESPONSIVIDADE ===== */

  @media (min-width: 480px) {
    .internal-links ul {
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--space-3) var(--space-6);
    }
  }

  @media (max-width: 480px) {
    .team-links-grid {
      grid-template-columns: 1fr;
    }

    .team-name {
      font-size: var(--font-size-xl);
    }

    .match-detail-card {
      padding: var(--space-4);
    }
  }

  @media (min-width: 768px) {
    .match-detail-card h2,
    .match-team-links h2,
    .share-section h2 {
      font-size: var(--font-size-2xl);
    }

    .team-name {
      font-size: var(--font-size-3xl);
    }

    .match-vs {
      font-size: var(--font-size-2xl);
    }
  }
</style>
